         accessTokenFactory: () => {
           const token = localStorage.getItem('accessToken')
           return token || ''
+        },
+        headers: {
+          ...(TUNNEL_AUTH_USER && TUNNEL_AUTH_PASSWORD ? {
+            'Authorization': `Basic ${btoa(`${TUNNEL_AUTH_USER}:${TUNNEL_AUTH_PASSWORD}`)}`
+          } : {})
